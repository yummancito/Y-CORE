{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "../dist-electron",
    "rootDir": "..",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "..",
    "paths": {
      "@y-core/shared": ["packages/shared/src"]
    }
  },
  "include": ["./**/*.ts", "../packages/shared/src/**/*.ts"]
}
