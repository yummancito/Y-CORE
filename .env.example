# Y-Core Electron + Renderer Environment Variables

# API URL (renderer → Y-Core API server)
VITE_YCORE_API_URL=http://localhost:3000

# Discord Rich Presence — Client Secret de la app de Discord.
# Developer Portal > tu app > OAuth2 > Client Secret.
# Requerido solo para mostrar la portada de Steam por juego (external assets).
DISCORD_CLIENT_SECRET=
