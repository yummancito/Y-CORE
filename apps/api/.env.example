# Y-Core API Environment Variables

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Supabase (required, all environments) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- JWT (required in production) ---
JWT_SECRET=generate-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m

# --- CORS (comma-separated origins, required in production) ---
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Rate limiting ---
GLOBAL_RATE_LIMIT_MAX=300
RATE_LIMIT_MAX=20

# --- DepotBox (optional, required for DepotBox import flow) ---
DEPOTBOX_API_KEY=your-depotbox-api-key

# --- GitHub (required in production, for manifest storage) ---
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_MANIFESTS_REPO=yummancito/y-core-manifests
GITHUB_SIGNATURES_REPO=OpenSteam001/steam-monitor

# --- Email service (required in production for password reset) ---
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@y-core.app

# --- Keep-alive self-ping (optional, Render free tier) ---
RENDER_EXTERNAL_URL=https://your-app.onrender.com

